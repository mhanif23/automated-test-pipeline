{
  "name": "automated-test-pipeline",
  "version": "1.0.0",
  "description": "Automated Testing in DevOps CI/CD Pipeline — Unit, API, and UI/E2E tests with quality gates",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "npm run test:unit && npm run test:api && npm run test:e2e:playwright && npm run test:e2e:selenium",
    "test:unit": "jest tests/unit --verbose",
    "test:api": "jest tests/api --verbose",
    "test:e2e:playwright": "npx playwright test",
    "test:e2e:playwright:headed": "npx playwright test --headed --workers=1",
    "test:e2e:playwright:ui": "npx playwright test --ui",
    "test:e2e:selenium": "jest tests/e2e/selenium --verbose --testTimeout=30000",
    "test:e2e:selenium:headed": "npx cross-env SELENIUM_HEADED=true jest tests/e2e/selenium --verbose --testTimeout=30000 --runInBand",
    "test:preview": "npm run test:e2e:playwright:headed && npm run test:e2e:selenium:headed"
  },
  "keywords": ["testing", "ci-cd", "playwright", "selenium", "devops"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "selenium-webdriver": "^4.27.0",
    "supertest": "^7.0.0"
  }
}
